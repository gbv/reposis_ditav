<?xml version="1.0" encoding="UTF-8"?>

<xed:template xmlns:xed="http://www.mycore.de/xeditor" xmlns:mir="http://www.mycore.de/mir">

  <xed:modify ref="admin.fields">
    <xed:include ref="gazin_genres" after="sdnb.repeat" />
    <xed:include ref="lod_archives" after="gazin_genres" />
    <xed:include ref="lod_document_classification" after="lod_archives" />
    <xed:include ref="koloe_document_classification" after="lod_document_classification" />
    <xed:include ref="koloe_topic_classification" after="koloe_document_classification" />
    <xed:include ref="koloe_continents" after="koloe_topic_classification" />
    <xed:include ref="koloe_period" after="koloe_continents" />
    <xed:include ref="ditav_translation" after="comment.complex" />
    <xed:include ref="ditav_transcription" after="ditav_translation" />
    <xed:include ref="ditav_translation_available" after="ditav_transcription" />
    <xed:include ref="ditav_scan_available" after="ditav_transcription" />
    <xed:include ref="sdnb.repeat.optional" after="sdnb.repeat" />
    <xed:remove ref="sdnb.repeat" />
  </xed:modify>

  <!-- ============ admin ============== -->


  <xed:template id="ditav.admin.fields">
    <xed:include ref="failed-validation-messages" />

    <xed:bind xpath="../../../../service">
      <xed:include ref="status" />
    </xed:bind>

    <xed:include ref="genre" />
    <xed:include ref="lod_document_classification" />
    <!--    <xed:include ref="toc-layout" />-->
    <xed:include ref="title.complex.repeated" />
    <xed:include ref="name.extended.full.repeated" />
    <xed:include ref="date.range.extended.datetimepicker" />
    <xed:include ref="place" />
    <xed:include ref="creator.place" />
    <xed:include ref="creator" />
    <xed:include ref="extent" />
    <xed:include ref="type.of.resource" />
    <xed:include ref="language" />
    <xed:include ref="geographicAndCartographics" />
    <xed:include ref="identifier.managed" />
    <xed:include ref="identifier.repeated" />
    <xed:include ref="lod_archives" />
    <xed:include ref="shelfmark" />
    <!--<xed:include
    ref="link.repeated" />-->
    <!--<xed:include
    ref="embargo" />-->
    <xed:include ref="rights" />
    <!--<xed:include
    ref="copyrightMD" /> -->
    <!-- <xed:include ref="institutes" /> -->
    <xed:include ref="subject.complex" />
    <!-- <xed:include ref="abstract.repeated" /> -->
    <!--<xed:include
    ref="related.item.search.of.all.items" />-->
    <xed:include ref="ditav_translation" />
    <xed:include ref="ditav_transcription" />
    <xed:include ref="ditav_translation_available" />
    <xed:include ref="ditav_scan_available" />
    <xed:include ref="comment.complex" />
    <xed:include ref="related.item.other.search.of.all.items" />
  </xed:template>

  <!-- ========== genres ========== -->

  <xed:template id="ditav.genres.common">
    <xed:include ref="gazin_genres" after="geographicAndCartographics" />
    <xed:include ref="lod_archives" after="gazin_genres" />
    <xed:include ref="lod_document_classification" after="lod_archives" />
    <xed:include ref="koloe_document_classification" after="lod_document_classification" />
    <xed:include ref="koloe_topic_classification" after="koloe_document_classification" />
    <xed:include ref="koloe_continents" after="koloe_topic_classification" />
    <xed:include ref="koloe_period" after="koloe_continents" />
    <xed:include ref="ditav_translation" after="comment.complex" />
    <xed:include ref="ditav_transcription" after="ditav_translation" />
    <xed:include ref="ditav_translation_available" after="ditav_transcription" />
    <xed:include ref="ditav_scan_available" after="ditav_transcription" />
  </xed:template>

  <xed:template id="ditav.lod.common">

    <xed:include ref="failed-validation-messages" />

    <xed:bind xpath="../../../../service">
      <xed:include ref="status" />
    </xed:bind>

    <h3 class="h5 mt-4 mb-3">
      <xed:output i18n="lod.editor.section.frontend" />
    </h3>
    <xed:include ref="lod.title.original" />
    <xed:include ref="lod.title.translated" />
    <xed:include ref="lod.abstract.repeated" />
    <xed:include ref="lod_document_classification" />
    <xed:include ref="language" />
    <xed:include ref="originInfo.agents.created" />
    <xed:include ref="lod.translator.repeated" />
    <xed:include ref="date.range.created.datetimepicker" />
    <xed:include ref="date.range.received.datetimepicker" />
    <xed:include ref="place" />
    <xed:include ref="geographicAndCartographics" />
    <xed:include ref="subject.repeated" />
    <xed:include ref="extent" />
    <xed:include ref="creator" />
    <xed:include ref="lod_archives" />
    <xed:include ref="shelfmark" />

    <h3 class="h5 mt-4 mb-3">
      <xed:output i18n="lod.editor.section.internal" />
    </h3>

    <xed:include ref="genre" />
    <xed:include ref="originInfo.agents.received" />
    <xed:include ref="ditav_translation" after="comment.complex" />
    <xed:include ref="ditav_transcription" after="ditav_translation" />
    <xed:include ref="ditav_translation_available" after="ditav_transcription" />
    <xed:include ref="ditav_scan_available" after="ditav_transcription" />
    <xed:include ref="identifier.managed" />
    <xed:include ref="identifier.repeated" />
    <xed:include ref="link.repeated" />
    <xed:include ref="rights" />
    <xed:include ref="comment.complex" />
    <xed:include ref="related.item.other.search.of.all.items" />

  </xed:template>

  <xed:template id="ditav.lod.edition">

    <xed:include ref="failed-validation-messages" />

    <xed:bind xpath="../../../../service">
      <xed:include ref="status" />
    </xed:bind>

    <xed:include ref="lod.frontend" />
    <!--<xed:include
    ref="lod.internal" />-->
    <xed:include ref="lod.edition.bind" />
    <xed:include ref="lod.relItemsearch.edition" />

  </xed:template>


  <xed:template id="genres.article">
    <xed:include ref="ditav.admin.fields" />
  </xed:template>

  <xed:template id="genres.source_material">
    <xed:include ref="ditav.admin.fields" />
  </xed:template>

  <xed:template id="genres.archival_material">
    <xed:include ref="ditav.lod.common" />
  </xed:template>

  <xed:template id="genres.autobiography">
    <xed:include ref="ditav.lod.common" />
  </xed:template>

  <xed:template id="genres.diplomatic_document">
    <xed:include ref="ditav.lod.edition" />
  </xed:template>

  <xed:template id="genres.ego_document">
    <xed:include ref="ditav.lod.common" />
  </xed:template>

  <xed:template id="genres.fiction">
    <xed:include ref="ditav.lod.common" />
  </xed:template>

  <xed:template id="genres.financial_document">
    <xed:include ref="ditav.lod.common" />
  </xed:template>

  <xed:template id="genres.language_exercise">
    <xed:include ref="ditav.lod.common" />
  </xed:template>

  <xed:template id="genres.legal_document">
    <xed:include ref="ditav.lod.common" />
  </xed:template>

  <xed:template id="genres.letter">
    <xed:include ref="ditav.lod.common" />
  </xed:template>

  <xed:template id="genres.official_document">
    <xed:include ref="ditav.lod.common" />
  </xed:template>

  <xed:template id="genres.other">
    <xed:include ref="ditav.lod.common" />
  </xed:template>

  <xed:template id="genres.training_guide">
    <xed:include ref="ditav.lod.common" />
  </xed:template>

  <xed:template id="genres.transfer_document">
    <xed:include ref="ditav.lod.common" />
  </xed:template>

  <xed:template id="genres.travelogue">
    <xed:include ref="ditav.lod.common" />
  </xed:template>

  <xed:template id="genres.edition">
    <xed:include ref="ditav.lod.common" />
  </xed:template>

  <xed:template id="genres.series">
    <xed:include ref="ditav.admin.fields" />
  </xed:template>

  <xed:template id="genres.interview">
    <xed:include ref="ditav.lod.common" />
  </xed:template>

  <!-- LOD templates -->


  <!-- ========== templates ========== -->

  <xed:template id="lod.frontend">
    <div class="border rounded p-3 mb-4">
      <h2>
        <xed:output i18n="lod.editor.section.frontend" />
      </h2>

      <!-- Title (Language) -->
      <xed:bind xpath="mods:titleInfo">
        <div class="mir-form-group row align-items-center mb-0 {$xed-validation-marker}">
          <label
            class="col-md-3 col-form-label mir-formgroup-label form-label d-flex justify-content-end align-items-center gap-2 text-nowrap pe-3">
            <xed:output i18n="lod.editor.title.label" />
            <xed:bind xpath="@xml:lang"
              initially="en">
              <select
                class="form-control form-control-inline lang-select form-select ms-1 flex-grow-1"
                data-dlang="{$MCR.Metadata.DefaultLang}"
                data-langs="{$MCR.Metadata.Languages}">
                <xed:choose>
                  <xed:when test="string-length(.) &gt; 0">
                    <option value="{.}" selected="">
                      <xed:output value="." />
                    </option>
                  </xed:when>
                  <xed:otherwise>
                    <option value="{$MCR.Metadata.DefaultLang}" selected="">
                      <xed:output value="{$MCR.Metadata.DefaultLang}" />
                    </option>
                  </xed:otherwise>
                </xed:choose>
              </select>
            </xed:bind>
          </label>
          <div class="col-md-6 d-flex align-items-center">
            <xed:bind xpath="mods:title">
              <input type="text" class="form-control"
                placeholder="{i18n:mir.editor.title.placeholder}" />
            </xed:bind>
          </div>
          <div class="col-md-3 text-nowrap">
            <mir:help-pmud help-text="{i18n:mir.help.title}" pmud="false" />
          </div>
        </div>
      </xed:bind>

      <!-- Translated title (Language) -->
      <xed:repeat xpath="mods:titleInfo[@type='translated']" min="1" max="6">
        <div class="mir-form-group row align-items-center {$xed-validation-marker}">
          <label
            class="col-md-3 col-form-label mir-formgroup-label form-label d-flex justify-content-end align-items-center gap-2 text-nowrap pe-3">
            <xed:output i18n="lod.editor.title-translated.label" />
            <xed:bind xpath="@xml:lang"
              initially="en">
              <select
                class="form-control form-control-inline lang-select form-select ms-1 flex-grow-1"
                data-dlang="{$MCR.Metadata.DefaultLang}"
                data-langs="{$MCR.Metadata.Languages}">
                <xed:choose>
                  <xed:when test="string-length(.) &gt; 0">
                    <option value="{.}" selected="">
                      <xed:output value="." />
                    </option>
                  </xed:when>
                  <xed:otherwise>
                    <option value="{$MCR.Metadata.DefaultLang}" selected="">
                      <xed:output value="{$MCR.Metadata.DefaultLang}" />
                    </option>
                  </xed:otherwise>
                </xed:choose>
              </select>
            </xed:bind>
          </label>
          <div class="col-md-6 d-flex align-items-center">
            <xed:bind xpath="mods:title">
              <input type="text" class="form-control"
                placeholder="{i18n:lod.editor.title-in-language.placeholder}" />
            </xed:bind>
          </div>
          <div class="col-md-3 text-nowrap">
            <mir:help-pmud help-text="{i18n:lod.editor.title-in-language.validation}" pmud="true" />
          </div>
        </div>
      </xed:repeat>

      <!-- Author -->
      <xed:bind xpath="mods:originInfo[@eventType='created']">

        <xed:repeat xpath="mods:agent[@type='personal']" min="0" max="10">
          <div
            class="mir-form-group row align-items-center {$xed-validation-marker} border rounded p-3 mb-3">
            <xed:bind xpath="mods:role/mods:roleTerm[@authority='marcrelator'][@type='code']">
              <input type="hidden" value="aut" />
            </xed:bind>
            <label
              class="col-md-3 col-form-label mir-formgroup-label form-label d-flex justify-content-end align-items-center gap-2 text-nowrap pe-3">
              <xed:output i18n="lod.editor.originInfo.created.author" />
            </label>
            <div class="col-md-6 d-flex align-items-center">
              <xed:bind xpath="mods:displayForm">
                <input type="text" class="form-control"
                  placeholder="{i18n:mir.editor.title.placeholder}" />
              </xed:bind>
            </div>
            <div class="col-md-3 text-nowrap">
              <mir:help-pmud help-text="{i18n:lod.editor.agent.displayForm.help}" pmud="true" />
            </div>
            <div
              class="col-md-3 col-form-label mir-formgroup-label form-label d-flex justify-content-end align-items-center gap-2 text-nowrap pe-3"></div>
            <div class="col-md-6 align-items-center">
              <details>
                <summary class="btn btn-outline-secondary btn-sm">
                  <xed:output i18n="lod.editor.agent.details" />
                </summary>
                <div class="mt-2 border rounded p-3">
                  <mir:textfield xpath="mods:namePart[@type='family']"
                    label="mir.editor.subject.name.editor.namePart.type.family"
                    help-text="{i18n:mir.help.name.family}" />

                  <mir:textfield xpath="mods:namePart[@type='given']"
                    label="mir.editor.subject.name.editor.namePart.type.given"
                    help-text="{i18n:mir.help.name.given}" />

                  <mir:textfield xpath="mods:nameIdentifier[@type='dante']"
                    label="lod.editor.agent.nameIdentifier"
                    help-text="{i18n:lod.editor.agent.nameIdentifier.help}"
                    placeholder="{i18n:lod.editor.agent.nameIdentifier.uuid}" />

                  <xed:bind xpath="mods:nameIdentifier[@type='dante']/@typeURI"
                    initially="https://uri.gbv.de/terminology/lod_persons/">
                    <input type="hidden" />
                  </xed:bind>

                  <mir:textfield xpath="mods:description"
                    label="lod.editor.agent.description"
                    help-text="{i18n:lod.editor.agent.description.help}"
                    placeholder="{i18n:lod.editor.agent.description.placeholder}" />
                </div>
              </details>
            </div>

          </div>
        </xed:repeat>

        <!-- Date of creation -->
        <mir:textfield xpath="mods:displayDate"
          label="lod.editor.originInfo.created.displayDate"
          help-text="{i18n:lod.editor.originInfo.created.displayDate.help}"
          placeholder="{i18n:lod.editor.originInfo.created.displayDate.placeholder}" />

        <!-- Place of creation -->
        <xed:repeat xpath="mods:place" min="0" max="10">

          <div
            class="mir-form-group row align-items-center {$xed-validation-marker} border rounded p-3 mb-3">
            <label
              class="col-md-3 col-form-label mir-formgroup-label form-label d-flex justify-content-end align-items-center gap-2 text-nowrap pe-3">
              <xed:output i18n="lod.editor.originInfo.created.placeTerm" />
            </label>
            <div class="col-md-6 d-flex align-items-center">
              <xed:bind xpath="mods:placeTerm">
                <input type="text" class="form-control"
                  placeholder="{i18n:lod.editor.originInfo.created.placeTerm.placeholder}" />
              </xed:bind>
            </div>
            <div class="col-md-3 text-nowrap">
              <mir:help-pmud help-text="{i18n:lod.editor.originInfo.created.placeTerm.help}"
                pmud="true" />
            </div>

            <div
              class="col-md-3 col-form-label mir-formgroup-label form-label d-flex justify-content-end align-items-center gap-2 text-nowrap pe-3"></div>
            <div class="col-md-6 align-items-center">
              <details>
                <summary class="btn btn-outline-secondary btn-sm">
                  <xed:output i18n="lod.editor.agent.details" />
                </summary>
                <div class="mt-2 border rounded p-3">
                  <mir:textfield
                    xpath="mods:placeIdentifier"
                    label="lod.editor.originInfo.created.placeIdentifier"
                    help-text="{i18n:lod.editor.originInfo.created.placeIdentifier.help}"
                    placeholder="{i18n:lod.editor.originInfo.created.placeIdentifier.placeholder}" />

                  <mir:textfield
                    xpath="mods:cartographics/coordinates"
                    label="lod.editor.originInfo.created.coordinates"
                    help-text="{i18n:mir.help.place}"
                    placeholder="{i18n:lod.editor.originInfo.created.coordinates.placeholder}" />
                </div>
              </details>
            </div>
          </div>
        </xed:repeat>

      </xed:bind>

      <!-- Recipient -->
      <xed:bind xpath="mods:originInfo[@eventType='received']">

        <xed:repeat xpath="mods:agent[@type='personal']" min="0" max="10">
          <div
            class="mir-form-group row align-items-center {$xed-validation-marker} border rounded p-3 mb-3">
            <xed:bind xpath="mods:role/mods:roleTerm[@authority='marcrelator'][@type='code']">
              <input type="hidden" value="rcp" />
            </xed:bind>
            <label
              class="col-md-3 col-form-label mir-formgroup-label form-label d-flex justify-content-end align-items-center gap-2 text-nowrap pe-3">
              <xed:output i18n="lod.editor.originInfo.received.recipient" />
            </label>
            <div class="col-md-6 d-flex align-items-center">
              <xed:bind xpath="mods:displayForm">
                <input type="text" class="form-control"
                  placeholder="{i18n:mir.editor.title.placeholder}" />
              </xed:bind>
            </div>
            <div class="col-md-3 text-nowrap">
              <mir:help-pmud help-text="{i18n:lod.editor.agent.displayForm.help}" pmud="true" />
            </div>
            <div
              class="col-md-3 col-form-label mir-formgroup-label form-label d-flex justify-content-end align-items-center gap-2 text-nowrap pe-3"></div>
            <div class="col-md-6 align-items-center">
              <details>
                <summary class="btn btn-outline-secondary btn-sm">
                  <xed:output i18n="lod.editor.agent.details" />
                </summary>
                <div class="mt-2 border rounded p-3">
                  <mir:textfield xpath="mods:namePart[@type='family']"
                    label="mir.editor.subject.name.editor.namePart.type.family"
                    help-text="{i18n:mir.help.name.family}" />

                  <mir:textfield xpath="mods:namePart[@type='given']"
                    label="mir.editor.subject.name.editor.namePart.type.given"
                    help-text="{i18n:mir.help.name.given}" />

                  <mir:textfield xpath="mods:nameIdentifier[@type='dante']"
                    label="lod.editor.agent.nameIdentifier"
                    help-text="{i18n:lod.editor.agent.nameIdentifier.help}"
                    placeholder="{i18n:lod.editor.agent.nameIdentifier.uuid}" />

                  <xed:bind xpath="mods:nameIdentifier[@type='dante']/@typeURI"
                    initially="https://uri.gbv.de/terminology/lod_persons/">
                    <input type="hidden" />
                  </xed:bind>

                  <mir:textfield xpath="mods:description"
                    label="lod.editor.agent.description"
                    help-text="{i18n:lod.editor.agent.description.help}"
                    placeholder="{i18n:lod.editor.agent.description.placeholder}" />
                </div>
              </details>
            </div>

          </div>
        </xed:repeat>

        <!-- Date of reception -->
        <mir:textfield xpath="mods:displayDate"
          label="lod.editor.originInfo.received.displayDate"
          help-text="{i18n:lod.editor.originInfo.received.displayDate.help}"
          placeholder="{i18n:lod.editor.originInfo.received.displayDate.placeholder}" />

        <!-- Place of reception -->
        <xed:repeat xpath="mods:place" min="0" max="10">

          <div
            class="mir-form-group row align-items-center {$xed-validation-marker} border rounded p-3 mb-3">
            <label
              class="col-md-3 col-form-label mir-formgroup-label form-label d-flex justify-content-end align-items-center gap-2 text-nowrap pe-3">
              <xed:output i18n="lod.editor.originInfo.received.placeTerm" />
            </label>
            <div class="col-md-6 d-flex align-items-center">
              <xed:bind xpath="mods:placeTerm">
                <input type="text" class="form-control"
                  placeholder="{i18n:lod.editor.originInfo.received.placeTerm.placeholder}" />
              </xed:bind>
            </div>
            <div class="col-md-3 text-nowrap">
              <mir:help-pmud help-text="{i18n:lod.editor.originInfo.received.placeTerm.help}"
                pmud="true" />
            </div>

            <div
              class="col-md-3 col-form-label mir-formgroup-label form-label d-flex justify-content-end align-items-center gap-2 text-nowrap pe-3"></div>
            <div class="col-md-6 align-items-center">
              <details>
                <summary class="btn btn-outline-secondary btn-sm">
                  <xed:output i18n="lod.editor.agent.details" />
                </summary>
                <div class="mt-2 border rounded p-3">
                  <mir:textfield
                    xpath="mods:placeIdentifier"
                    label="lod.editor.originInfo.received.placeIdentifier"
                    help-text="{i18n:lod.editor.originInfo.received.placeIdentifier.help}"
                    placeholder="{i18n:lod.editor.originInfo.received.placeIdentifier.placeholder}" />

                  <mir:textfield
                    xpath="mods:cartographics/coordinates"
                    label="lod.editor.originInfo.received.coordinates"
                    help-text="{i18n:mir.help.place}"
                    placeholder="{i18n:lod.editor.originInfo.received.coordinates.placeholder}" />
                </div>
              </details>
            </div>
          </div>
        </xed:repeat>

      </xed:bind>

      <!-- Language -->
      <xed:include ref="language" />

      <!-- Document type -->
      <xed:include ref="lod_mir_genres" />

      <!-- Document subtype -->
      <xed:include ref="lod_document_classification" />

      <!-- Topic -->
      <mir:textfield
        xpath="mods:subject/mods:topic"
        label="lod.editor.subject.topic.label" help-text="{i18n:lod.editor.subject.topic.help}" />

      <!-- Cited persons -->


      <!-- Cited institutions -->
      <xed:repeat xpath="mods:subject" min="0" max="20">
        <xed:repeat xpath="mods:name" min="1" max="1">
          <div
            class="mir-form-group row align-items-center {$xed-validation-marker} border rounded p-3 mb-3">
            <label class="col-md-3 col-form-label">
              <xed:bind xpath="@type">
                <select class="form-control form-select" data-mapping="lod_subject_type">
                  <option value="">
                    <xed:output i18n="lod.editor.subject.type.label" />
                  </option>
                  <option value="personal">
                    <xed:output i18n="lod.editor.subject.type.person" />
                  </option>
                  <option value="corporate">
                    <xed:output i18n="lod.editor.subject.type.corporate" />
                  </option>
                </select>
              </xed:bind>
            </label>
            <xed:bind xpath="mods:role/mods:roleTerm[@authority='marcrelator'][@type='code']">
              <input type="hidden" value="asn" />
            </xed:bind>
            <div class="col-md-6 d-flex align-items-center">
              <xed:bind xpath="mods:displayForm">
                <input type="text" class="form-control"
                  placeholder="{i18n:mir.editor.title.placeholder}" />
              </xed:bind>
            </div>

            <div class="col-md-3 text-nowrap">
              <mir:help-pmud help-text="{i18n:lod.editor.agent.displayForm.help}" pmud="true" />
            </div>

            <div
              class="col-md-3 col-form-label mir-formgroup-label form-label d-flex justify-content-end align-items-center gap-2 text-nowrap pe-3"></div>
            <div class="col-md-6 align-items-center">
              <details>
                <summary class="btn btn-outline-secondary btn-sm">
                  <xed:output i18n="lod.editor.agent.details" />
                </summary>
                <div class="mt-2 border rounded p-3">
                  <mir:textfield xpath="mods:namePart[@type='family']"
                    label="mir.editor.subject.name.editor.namePart.type.family"
                    help-text="{i18n:mir.help.name.family}" />

                  <mir:textfield xpath="mods:namePart[@type='given']"
                    label="mir.editor.subject.name.editor.namePart.type.given"
                    help-text="{i18n:mir.help.name.given}" />

                  <mir:textfield xpath="mods:nameIdentifier[@type='dante']"
                    label="lod.editor.agent.nameIdentifier"
                    help-text="{i18n:lod.editor.agent.nameIdentifier.help}"
                    placeholder="{i18n:lod.editor.agent.nameIdentifier.uuid}" />

                  <xed:bind xpath="mods:nameIdentifier[@type='dante']/@typeURI"
                    initially="https://uri.gbv.de/terminology/lod_persons/">
                    <input type="hidden" />
                  </xed:bind>

                  <mir:textfield xpath="mods:description"
                    label="lod.editor.agent.description"
                    help-text="{i18n:lod.editor.agent.description.help}"
                    placeholder="{i18n:lod.editor.agent.description.placeholder}" />
                </div>
              </details>
            </div>
          </div>
        </xed:repeat>
      </xed:repeat>


      <!-- Translation -->
      <xed:include ref="ditav_translation" />

      <!-- Comment -->
      <mir:textfield xpath="mods:note[@type='source_note']" label="lod.editor.note.comment.label"
        help-text="{i18n:lod.editor.note.comment.help}"
        placeholder="{i18n:lod.editor.note.comment.placeholder}" />

      <!-- Comment on language -->
      <mir:textfield xpath="mods:note[@type='language']" label="lod.editor.note.language.label"
        help-text="{i18n:lod.editor.note.language.help}"
        placeholder="{i18n:lod.editor.note.language.placeholder}" />


      <!-- Original or copy -->
      <mir:textfield xpath="mods:note[@type='original_or_copy']"
        label="lod.editor.note.originalOrCopy.label"
        help-text="{i18n:lod.editor.note.originalOrCopy.help}"
        placeholder="{i18n:lod.editor.note.originalOrCopy.placeholder}" />

      <!-- Number of folios in the record -->
      <mir:textfield xpath="mods:physicalDescription/mods:extent" label="lod.editor.extent.label"
        help-text="{i18n:lod.editor.extent.help}" placeholder="{i18n:lod.editor.extent.placeholder}" />

      <xed:include ref="lod_archives" />

      <xed:include ref="shelfmark" />


    </div>
  </xed:template>

  <xed:template id="lod.internal">
    <fieldset>
      <legend class="mir-fieldset-legend">
        <xed:output i18n="lod.editor.section.internal" />
      </legend>
      <xed:include ref="genre" />
      <xed:include ref="originInfo.agents.received" />
      <xed:include ref="ditav_translation" after="comment.complex" />
      <xed:include ref="ditav_transcription" after="ditav_translation" />
      <xed:include ref="ditav_translation_available" after="ditav_transcription" />
      <xed:include ref="ditav_scan_available" after="ditav_transcription" />
      <xed:include ref="note.complex" />
      <xed:include ref="identifier.managed" />
      <xed:include ref="identifier.other" />
      <xed:include ref="link.repeated" />
      <xed:include ref="rights" />
      <xed:include ref="comment.complex" />
      <xed:include ref="related.item.other.search.of.all.items" />
    </fieldset>
  </xed:template>

  <xed:template id="genre.base">
    <label class="col-md-3 col-form-label text-end form-label">
      <xed:output i18n="lod_document_classification.type.label" />
    </label>
    <div class="col-md-6">
      <div class="controls">
        <select class="form-control form-control-inline form-select">
          <option value="">
            <xed:output i18n="mir.select" />
          </option>
          <xed:include uri="xslStyle:items2options:classification:editor:-1:children:mir_genres" />
        </select>
      </div>
    </div>
  </xed:template>

  <xed:template id="title.original">
    <xed:bind xpath="mods:titleInfo">
      <div class="mir-fieldset-content">
        <mir:textfield xpath="mods:title" label="mir.title.type.original"
          placeholder="{i18n:mir.placeholder.title.main}" help-text="{i18n:mir.help.title}"
          class="required" required="true" required-i18n="mir.validation.title" />
      </div>
    </xed:bind>
  </xed:template>

  <xed:template id="lod.title.original">
    <xed:bind xpath="mods:titleInfo">
      <div class="mir-fieldset-content">
        <div class="mir-form-group row required {$xed-validation-marker}">
          <label class="col-md-3 col-form-label text-end form-label">
            <xed:output i18n="mir.title" />
          </label>
          <div class="col-md-6">
            <div class="row g-2 align-items-center">
              <div class="col-8">
                <xed:bind xpath="mods:title">
                  <input type="text" class="form-control"
                    placeholder="{i18n:mir.placeholder.title.main}" />
                </xed:bind>
              </div>
              <div class="col-4">
                <xed:bind xpath="@xml:lang" initially="de">
                  <xed:include ref="lang.list" />
                </xed:bind>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <mir:help-pmud help-text="{i18n:mir.help.title}" pmud="false" />
          </div>
        </div>
      </div>
    </xed:bind>
  </xed:template>

  <xed:template id="lod.title.translated">
    <xed:repeat xpath="mods:titleInfo[@type='translated']" min="1" max="6">
      <div class="mir-fieldset-content">
        <div class="mir-form-group row">
          <label class="col-md-3 col-form-label text-end mir-formgroup-label form-label">
            <xed:output i18n="mir.title" />
          </label>
          <div class="col-md-6">
            <div class="row g-2 align-items-center">
              <div class="col-8">
                <xed:bind xpath="mods:title">
                  <input type="text" class="form-control"
                    placeholder="{i18n:mir.placeholder.title.translated}" />
                </xed:bind>
              </div>
              <div class="col-4">
                <xed:bind xpath="@xml:lang" initially="de">
                  <xed:include ref="lang.list" />
                </xed:bind>
              </div>
            </div>
          </div>
          <mir:help-pmud help-text="{i18n:mir.help.sdnb}" pmud="true" />
        </div>
      </div>
    </xed:repeat>
  </xed:template>

  <xed:template id="title.translated">
    <fieldset>
      <legend class="mir-fieldset-legend">
        <xed:output i18n="mir.title.type.translated" />
      </legend>
      <xed:repeat xpath="mods:titleInfo[@type='translated']" min="1" max="6">
        <div class="mir-fieldset-content">
          <div class="mir-form-group row">
            <label class="col-md-3 col-form-label text-end mir-formgroup-label form-label">
              <xed:output i18n="mir.title" />
            </label>
            <div class="col-md-6">
              <xed:bind xpath="mods:title">
                <input type="text" class="form-control"
                  placeholder="{i18n:mir.placeholder.title.translated}" />
              </xed:bind>
            </div>
            <mir:help-pmud help-text="{i18n:mir.help.sdnb}" pmud="true" />
          </div>
          <mir:textfield xpath="mods:subTitle" label="mir.title.subTitle" />
          <div class="mir-form-group row">
            <label class="col-md-3 col-form-label text-end mir-formgroup-label form-label">
              <xed:output i18n="mir.language" />
            </label>
            <div class="col-md-6">
              <xed:bind xpath="@xml:lang" initially="de">
                <xed:include ref="lang.list" />
              </xed:bind>
            </div>
          </div>
        </div>
      </xed:repeat>
    </fieldset>
  </xed:template>


  <!--SDNB
  only optional -->
  <xed:template id="sdnb.repeat.optional">
    <xed:repeat xpath="mods:classification[@authority='sdnb'][@displayLabel='sdnb']" min="1"
      max="10" method="build">
      <div class="form-group row {$xed-validation-marker}">
        <label class="col-md-3 col-form-label text-right">
          <xed:output i18n="editor.search.mir.sdnb" /> : </label>
        <div class="col-md-6">
          <select class="form-control form-control-inline mir-form__js-select--large">
            <option value="">
              <xed:output i18n="mir.select" />
            </option>
            <xed:include uri="xslStyle:items2options:classification:editor:-1:children:SDNB" />
          </select>
        </div>
        <mir:help-pmud help-text="{i18n:mir.help.sdnb}" pmud="true" />
      </div>
    </xed:repeat>
  </xed:template>

