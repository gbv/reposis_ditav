        </div>
        <mir:help-pmud help-text="{i18n:lod.editor.metadata.lod_document_classification.help}"
          pmud="false" />
      </div>
    </xed:bind>
  </xed:template>

  <xed:template id="lod.archives">
    <xed:bind
      xpath="mods:classification[@authorityURI='https://ditav.gbv.de/api/v2/classifications/lod_archives'][@displayLabel='lod_archives']/@valueURIxEditor">
      <div class="form-group row {$xed-validation-marker}">
        <label class="col-md-3 col-form-label text-right">
          <xed:output i18n="lod.editor.metadata.lod_archives.label" />
        </label>
        <div class="col-md-6">
          <select class="form-control form-control-inline">
            <option value="">
              <xed:output i18n="mir.select" />
            </option>
            <xed:include
              uri="xslStyle:items2options:classification:editor:-1:children:lod_archives" />
          </select>
        </div>
        <mir:help-pmud help-text="{i18n:lod.editor.metadata.lod_archives.help}"
          pmud="false" />
      </div>
    </xed:bind>
  </xed:template>


  <xed:template id="lod.authorsender.repeated">
    <mir:role.repeated role="aut" label="lod.role.author_sender" help-text="{i18n:lod.role.help}" />
  </xed:template>

  <xed:template id="lod.recipient.repeated">
    <mir:role.repeated role="rcp" label="lod.role.recipient" help-text="{i18n:lod.role.help}" />
  </xed:template>

  <xed:template id="comment.complex">
    <fieldset>
      <legend class="mir-fieldset-legend">
        <xed:output i18n="mir.comment" />
      </legend>
      <xed:repeat xpath="mods:note" min="1" max="5">
        <div class="mir-fieldset-content">
          <div class="form-group row">
            <label class="col-md-3 col-form-label text-right">
              <xed:output i18n="mir.comment.type" />
            </label>
            <div class="col-md-6">
              <xed:bind xpath="@type">
                <select class="form-control">
                  <option value="">
                    <xed:output i18n="mir.select" />
                  </option>
                  <xed:include
                    uri="xslStyle:items2options,convertClassificationOptions:classification:editor:-1:children:noteTypes" />
                </select>
              </xed:bind>
            </div>
            <mir:help-pmud help-text="{i18n:mir.help.comment.type}" pmud="true" />
          </div>
          <mir:textarea xpath="." label="mir.comment" help-text="{i18n:mir.help.comment}" rows="3" />
        </div>
      </xed:repeat>
    </fieldset>
  </xed:template>

  <xed:template id="lod.translator.repeated">
    <mir:role.repeated role="trl" label="lod.role.translator"
      help-text="{i18n:lod.role.help}" />
  </xed:template>

  <xed:template id="lod.genre.base">
    <label class="col-md-3 col-form-label text-right">
      <xed:output i18n="lod.editor.genre.label" />
    </label>
    <div class="col-md-6">
      <div class="controls">
        <select class="form-control form-control-inline">
          <option value="">
            <xed:output i18n="mir.select" />
          </option>
          <xed:include uri="xslStyle:items2options:classification:editor:-1:children:mir_genres" />
        </select>
      </div>
    </div>
  </xed:template>

  <xed:template id="date.range.created.datetimepicker">
    <mir:dateRange
      xpath="mods:originInfo[@eventType='creation']/mods:dateCreated[@encoding='w3cdtf']"
      label="lod.editor.date.created" help-text="{i18n:mir.help.date.created.range}"
      class="datetimepicker" placeholder="{i18n:mir.placeholder.date}" />
    <!--ToDo:
    Kalendertyp zur Maske hinzufügen-->
    <!--     <xed:bind xpath="mods:originInfo[@eventType='creation']/mods:dateCreated">
      <div class="col-md-2">
        <xed:bind xpath="@calendar">
          <select class="form-control" style="font-weight:bold;">
            <option value="gregorian">
              <xed:output i18n="mir.characteristics.yes" />
            </option>
            <option value="julian">
              <xed:output i18n="mir.characteristics.no" />
            </option>
          </select>
        </xed:bind>
      </div>
    </xed:bind>
    -->
  </xed:template>

  <xed:template id="date.range.received.datetimepicker">
    <mir:dateRange
      xpath="mods:originInfo[@eventType='received']/mods:dateOther[@type='received'][@encoding='w3cdtf']"
      label="lod.editor.date.other"
      help-text="{i18n:mir.help.date.received.range}" class="datetimepicker"
      placeholder="{i18n:mir.placeholder.date}" />
  </xed:template>

  <xed:template id="lod.place.received">
    <mir:textfield
      xpath="mods:originInfo[@eventType='received']/mods:place/mods:placeTerm[@type='text']"
      label="mir.place.received" help-text="{i18n:mir.help.place}" />
  </xed:template>

  <xed:template id="lod.genre">
    <xed:load-resource name="mir_genres" uri="classification:metadata:-1:children:mir_genres" />
    <xed:if test="mods:genre[@type='intern'][not(@authorityURI)]">
      <xed:bind xpath="mods:genre[@type='intern'][not(@authorityURI)]">
        <xed:bind xpath="@authorityURI" set="{$mir_genres/label[@xml:lang='x-uri']/@text}" />
      </xed:bind>
    </xed:if>
    <xed:bind
      xpath="mods:genre[@type='intern'][@authorityURI=$mir_genres/label[@xml:lang='x-uri']/@text]">
      <xed:bind xpath="@valueURIxEditor" initially="{$genre}">
        <div class="form-group row required {$xed-validation-marker}">
          <xed:include ref="lod.genre.base" />
          <mir:help-pmud help-text="{i18n:lod.editor.genre.help}" pmud="false" />
        </div>
      </xed:bind>
    </xed:bind>
  </xed:template>

  <xed:template id="identifier.intern">
    <mir:textfield xpath="mods:identifier[@type='intern']" label="mir.identifier.intern"
      help-text="{i18n:mir.help.identifier.intern}" />
  </xed:template>

  <xed:template id="lod.abstract.repeated">
    <fieldset>
      <legend class="mir-fieldset-legend">
        <xed:output i18n="lod.editor.metadata.abstract.legend" />
      </legend>
      <xed:repeat xpath="mods:abstract" min="1" max="3">
        <div class="mir-fieldset-content">
          <div class="form-group row">
            <label class="col-md-3 col-form-label text-right">
              <xed:output i18n="lod.abstract.in" />
            </label>
            <div class="col-md-6">
              <xed:bind xpath="@xml:lang" initially="de">
                <xed:include ref="lang.list" />
              </xed:bind>
            </div>
            <mir:help-pmud help-text="{i18n:mir.help.abstract.language}" pmud="true" />
          </div>
          <mir:htmlArea xpath="." label="lod.editor.metadata.abstract.label"
            help-text="{i18n:mir.help.abstract.ortext}" rows="5" />
        </div>
      </xed:repeat>
    </fieldset>
  </xed:template>

  <xed:template id="hosts.edition">
    <xed:bind xpath="mods:relatedItem[@type='host']">
      <xed:bind xpath="@xlink:href" initially="{$MIR.projectid.default}_mods_00000000">
        <input id="relItem-edition" type="hidden" />
      </xed:bind>
      <xed:include ref="title.book.relItemsearch" />
      <xed:include ref="subtitle" />
      <xed:include ref="author.repeated" />
      <xed:include ref="editor.repeated" />
      <xed:include ref="hosts.collection.common.publisher" />
      <xed:include ref="identifier.isbn.book.relItemsearch" />
      <xed:include ref="shelfmark.book.relItemsearch" />
      <xed:include ref="host.pages" />
    </xed:bind>
  </xed:template>

  <xed:template id="author_desc.repeated">
    <mir:role.repeated role="exp" label="lod.editor.metadata.author_of_description.label"
      help-text="{i18n:mir.help.role.author}" />
  </xed:template>


  <!-- ========== originInfo with agents and places ========== -->

  <xed:template id="originInfo.agents.created">
    <fieldset>
      <legend class="mir-fieldset-legend">
        <xed:output i18n="lod.editor.originInfo.agents.legend" />
      </legend>

      <xed:repeat xpath="mods:originInfo[@eventType='created']" min="0" max="10">
        <div class="mir-fieldset-content">

          <!-- Event Type Selector -->
          <div class="form-group row">
            <label class="col-md-3 col-form-label text-right">
              <xed:output i18n="lod.editor.originInfo.eventType" />
            </label>
            <div class="col-md-6">
              <xed:bind xpath="@eventType">
                <select class="form-control form-select">
                  <option value="created">
                    <xed:output i18n="lod.editor.originInfo.created" />
                  </option>
                  <option value="received">
                    <xed:output i18n="lod.editor.originInfo.received" />
                  </option>
                </select>
              </xed:bind>
            </div>
            <mir:help-pmud help-text="{i18n:lod.editor.originInfo.eventType.help}" />
          </div>

          <!-- Agents (repeatable) -->
          <xed:repeat xpath="mods:agent[@type='personal']" min="0" max="10">
            <xed:include ref="originInfo.agent.personal" />
          </xed:repeat>

          <!-- Place Information -->
          <xed:if test="mods:place">
            <xed:include ref="originInfo.place" />
          </xed:if>

        </div>
      </xed:repeat>
    </fieldset>
  </xed:template>

  <xed:template id="originInfo.agents.received">
    <fieldset>
      <legend class="mir-fieldset-legend">
        <xed:output i18n="lod.editor.originInfo.agents.legend" />
      </legend>

      <xed:repeat xpath="mods:originInfo[@eventType='received']" min="0" max="10">
        <div class="mir-fieldset-content">

          <!-- Event Type Selector -->
          <div class="form-group row">
            <label class="col-md-3 col-form-label text-right">
              <xed:output i18n="lod.editor.originInfo.eventType" />
            </label>
            <div class="col-md-6">
              <xed:bind xpath="@eventType">
                <select class="form-control form-select">
                  <option value="created">
                    <xed:output i18n="lod.editor.originInfo.created" />
                  </option>
                  <option value="received">
                    <xed:output i18n="lod.editor.originInfo.received" />
                  </option>
                </select>
              </xed:bind>
            </div>
            <mir:help-pmud help-text="{i18n:lod.editor.originInfo.eventType.help}" />
          </div>

          <!-- Agents (repeatable) -->
          <xed:repeat xpath="mods:agent[@type='personal']" min="0" max="10">
            <xed:include ref="originInfo.agent.personal" />
          </xed:repeat>

          <!-- Place Information -->
          <xed:if test="mods:place">
            <xed:include ref="originInfo.place" />
          </xed:if>

        </div>
      </xed:repeat>
    </fieldset>
  </xed:template>

  <xed:template id="originInfo.agent.personal">
    <div class="mir-form-group border rounded p-3 mb-3">
      <fieldset>
        <legend class="mir-fieldset-legend">
          <xed:output i18n="lod.editor.agent.personal.legend" />
        </legend>

        <!-- Agent type (hidden, always personal) -->
        <xed:bind xpath="@type" initially="personal">
          <input type="hidden" />
        </xed:bind>

        <!-- Display Form (full name with search) -->
        <div class="form-group row">
          <label class="col-md-3 col-form-label text-right">
            <xed:output i18n="editor.label.author" />
          </label>
          <div class="col-md-6">
            <xed:bind xpath="mods:displayForm">
              <input type="hidden" />
              <div class="nameSearchApp" define-own-identifier="true"></div>
            </xed:bind>
          </div>
          <mir:help-pmud help-text="{i18n:lod.editor.agent.displayForm.help}" pmud="true" />
        </div>

        <!-- Family Name -->
        <mir:textfield xpath="mods:namePart[@type='family']"
          label="mir.editor.subject.name.editor.namePart.type.family"
          help-text="{i18n:mir.help.name.family}" />

        <!-- Given Name -->
        <mir:textfield xpath="mods:namePart[@type='given']"
          label="mir.editor.subject.name.editor.namePart.type.given"
          help-text="{i18n:mir.help.name.given}" />

        <!-- Role (marcrelator) -->
        <div class="form-group row">
          <label class="col-md-3 col-form-label text-right">
            <xed:output i18n="mir.role" />
          </label>
          <div class="col-md-6">
            <xed:bind xpath="mods:role/mods:roleTerm[@authority='marcrelator'][@type='code']">
              <select class="form-control form-select">
                <option value="">
                  <xed:output i18n="mir.select" />
                </option>
                <xed:include
                  uri="xslStyle:items2options:classification:editor:-1:children:marcrelator" />
              </select>
            </xed:bind>
            <xed:bind
              xpath="mods:role/mods:roleTerm[@authority='marcrelator'][@type='code']/@authorityURI"
              initially="http://id.loc.gov/vocabulary/relators">
              <input type="hidden" />
            </xed:bind>
          </div>
          <mir:help-pmud help-text="{i18n:lod.editor.agent.role.help}" pmud="true" />
        </div>

        <!-- Name Identifier UUID (DANTE) -->
        <mir:textfield xpath="mods:nameIdentifier[@type='dante']"
          label="lod.editor.agent.nameIdentifier"
          help-text="{i18n:lod.editor.agent.nameIdentifier.help}"
          placeholder="{i18n:lod.editor.agent.nameIdentifier.uuid}" />

        <!-- Name Identifier TypeURI (hidden) -->
        <xed:bind xpath="mods:nameIdentifier[@type='dante']/@typeURI"
          initially="https://uri.gbv.de/terminology/lod_persons/">
          <input type="hidden" />
        </xed:bind>

        <!-- Description -->
        <mir:textfield xpath="mods:description"
          label="lod.editor.agent.description"
          help-text="{i18n:lod.editor.agent.description.help}"
          placeholder="{i18n:lod.editor.agent.description.placeholder}" />

      </fieldset>
    </div>
  </xed:template>

  <xed:template id="originInfo.place">
    <div class="mir-form-group border rounded p-3 mb-3">
      <fieldset>
        <legend class="mir-fieldset-legend">
          <xed:output i18n="lod.editor.originInfo.place.legend" />
        </legend>

        <xed:bind xpath="mods:place">

          <!-- Place Term (text name) -->
          <mir:textfield xpath="mods:placeTerm[@type='text']"
            label="mir.place"
            help-text="{i18n:mir.help.place}"
            placeholder="{i18n:lod.editor.place.placeholder}" />

          <!-- Place Identifier (Geonames URI) -->
          <mir:textfield xpath="mods:placeIdentifier"
            label="lod.editor.place.identifier"
            help-text="{i18n:lod.editor.place.identifier.help}"
            placeholder="https://www.geonames.org/524894" />

          <xed:bind xpath="mods:placeIdentifier/@type" initially="uri">
            <input type="hidden" />
          </xed:bind>

          <!-- Coordinates -->
          <mir:textfield xpath="mods:cartographics/mods:coordinates"
            label="lod.editor.place.coordinates"
            help-text="{i18n:lod.editor.place.coordinates.help}"
            placeholder="{i18n:lod.editor.place.coordinates.placeholder}" />

        </xed:bind>
      </fieldset>
    </div>
  </xed:template>

  <xed:template id="subject.personal">
    <div class="mir-form-group border rounded p-3 mb-3">
      <fieldset>
        <legend class="mir-fieldset-legend">
          <xed:output i18n="lod.editor.agent.personal.legend" />
        </legend>

        <xed:bind xpath="mods:name[@type='personal']">
          <xed:bind xpath="@type" initially="personal">
            <input type="hidden" />
          </xed:bind>

          <div class="form-group row">
            <label class="col-md-3 col-form-label text-right">
              <xed:output i18n="editor.label.author" />
            </label>
            <div class="col-md-6">
              <xed:bind xpath="mods:displayForm">
                <input type="hidden" />
                <div class="nameSearchApp" define-own-identifier="true"></div>
              </xed:bind>
            </div>
            <mir:help-pmud help-text="{i18n:lod.editor.agent.displayForm.help}" pmud="true" />
          </div>

          <mir:textfield xpath="mods:namePart[@type='family']"
            label="mir.editor.subject.name.editor.namePart.type.family"
            help-text="{i18n:mir.help.name.family}" />

          <mir:textfield xpath="mods:namePart[@type='given']"
            label="mir.editor.subject.name.editor.namePart.type.given"
            help-text="{i18n:mir.help.name.given}" />

          <mir:textfield xpath="mods:nameIdentifier[@type='dante']"
            label="lod.editor.agent.nameIdentifier"
            help-text="{i18n:lod.editor.agent.nameIdentifier.help}"
            placeholder="{i18n:lod.editor.agent.nameIdentifier.uuid}" />

          <xed:bind xpath="mods:nameIdentifier[@type='dante']/@typeURI"
            initially="https://uri.gbv.de/terminology/lod_persons/">
            <input type="hidden" />
          </xed:bind>
        </xed:bind>
      </fieldset>
    </div>
  </xed:template>

  <xed:template id="subject.corporate">
    <div class="mir-form-group border rounded p-3 mb-3">
      <fieldset>
        <legend class="mir-fieldset-legend">
          <xed:output i18n="mir.publisherOrganization" />
        </legend>

        <xed:bind xpath="mods:name[@type='corporate']">
          <xed:bind xpath="@type" initially="corporate">
            <input type="hidden" />
          </xed:bind>

          <div class="form-group row">
            <label class="col-md-3 col-form-label text-right">
              <xed:output i18n="mir.publisherOrganization" />
            </label>
            <div class="col-md-6">
              <xed:bind xpath="mods:displayForm">
                <input type="text" size="26" class="form-control form-control-inline" />
              </xed:bind>
            </div>
            <mir:help-pmud help-text="{i18n:mir.help.editor.organization}" pmud="true" />
          </div>

          <mir:textfield xpath="mods:nameIdentifier[@type='dante']"
            label="lod.editor.agent.nameIdentifier"
            help-text="{i18n:lod.editor.agent.nameIdentifier.help}"
            placeholder="{i18n:lod.editor.agent.nameIdentifier.uuid}" />

          <xed:bind xpath="mods:nameIdentifier[@type='dante']/@typeURI"
            initially="https://uri.gbv.de/terminology/lod_organisations/">
            <input type="hidden" />
          </xed:bind>
        </xed:bind>
      </fieldset>
    </div>
  </xed:template>

  <xed:template id="subject.repeated">
    <fieldset>
      <legend class="mir-fieldset-legend">
        <xed:output i18n="mir.subject.topic.complex" />
      </legend>

      <xed:repeat xpath="mods:subject" min="0" max="10">
        <div class="mir-fieldset-content">
          <xed:bind xpath="@xlink:type" initially="simple">
            <input type="hidden" />
          </xed:bind>
          <xed:choose>
            <xed:when test="mods:name[@type='corporate']">
              <xed:include ref="subject.corporate" />
            </xed:when>
            <xed:otherwise>
              <xed:include ref="subject.personal" />
            </xed:otherwise>
          </xed:choose>
        </div>
      </xed:repeat>
    </fieldset>
  </xed:template>

  <!-- ========== validation ========== -->


</xed:template>
